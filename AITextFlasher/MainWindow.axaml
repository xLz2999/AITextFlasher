<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AITextFlasher.MainWindow"
        Title="AI文本转换器" Height="450" Width="600"
        Icon="/Assets/lively.ico"
        WindowStartupLocation="CenterScreen"
        Topmost="{Binding #TopmostCheck.IsChecked}"> <Border Padding="20" Background="#F5F7FA">
        <Grid RowDefinitions="Auto, *, Auto">
            
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                <TextBlock Text="⚡ AITextFlasher" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                <CheckBox x:Name="TopmostCheck" Grid.Column="1" Content="📌 窗口置顶" FontWeight="SemiBold" Foreground="#7F8C8D"/>
            </Grid>

            <Border Grid.Row="1" CornerRadius="10" Background="White" BoxShadow="0 4 15 0 #1A000000" ClipToBounds="True">
                <TextBox x:Name="InputTextBox" 
                         AcceptsReturn="True" 
                         TextWrapping="Wrap" 
                         Watermark="请在此处粘贴 AI 给你写的 Markdown 文本……"
                         BorderThickness="0"
                         Padding="15"
                         FontSize="15"
                         Background="Transparent"/>
            </Border>
            
            <Grid Grid.Row="2" ColumnDefinitions="Auto, *, Auto" Margin="0,20,0,0">
                <Button x:Name="BtnClear" Grid.Column="0" Content="🗑️ 一键清空" Click="BtnClear_Click" 
                        Background="#FFEBEE" Foreground="#D32F2F" CornerRadius="6" Padding="15,10" FontWeight="Bold"/>
                
                <TextBlock x:Name="StatusText" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" 
                           Margin="0,0,15,0" Foreground="#27AE60" FontWeight="Bold" FontSize="14"/>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Button x:Name="BtnToText" Content="📋 转纯文本并复制" Click="BtnToText_Click" 
                            Background="#E0E0E0" Foreground="#333333" CornerRadius="6" Padding="15,10" FontWeight="Bold"/>
                    <Button x:Name="BtnToWord" Content="📄 导出 Word" Click="BtnToWord_Click" 
                            Background="#2980B9" Foreground="White" CornerRadius="6" Padding="15,10" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
