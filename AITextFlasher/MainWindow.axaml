<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AITextFlasher.MainWindow"
        Title="AI文本转换器" Height="400" Width="500"
        Icon="/Assets/lively.ico">
    
    <Grid RowDefinitions="*, Auto" Margin="10">
        <TextBox x:Name="InputTextBox" 
                 Grid.Row="0" 
                 AcceptsReturn="True" 
                 TextWrapping="Wrap" 
                 Watermark="请在这里粘贴 AI 的 Markdown 回复……"/>
        
        <!-- 底部的一排按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <!-- 提示文字 -->
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Green"/>
            
            <Button x:Name="BtnToText" Content="复制 txt 到粘贴板" Click="BtnToText_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnToWord" Content="一键导出为 Word" Click="BtnToWord_Click" Classes="accent"/>
        </StackPanel>
    </Grid>
</Window>
